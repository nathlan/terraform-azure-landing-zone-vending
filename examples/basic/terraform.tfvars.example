# ========================================
# Common Configuration
# ========================================

subscription_billing_scope       = "YOUR_BILLING_SCOPE_HERE"
subscription_management_group_id = "Corp"
hub_network_resource_id          = "/subscriptions/xxx/resourceGroups/rg-hub/providers/Microsoft.Network/virtualNetworks/vnet-hub"
github_organization              = "yourorg"
azure_address_space               = "10.100.0.0/16"

tags = {
  managed_by       = "terraform"
  environment_type = "example"
}

# ========================================
# Landing Zones Configuration
# ========================================
#
# Define MULTIPLE landing zones to deploy in a single module call.
# Each key (e.g., "example-api-prod") represents a separate landing zone.

landing_zones = {
  example-api-prod = {
    workload = "example-api"
    env      = "prod"
    team     = "app-engineering"
    location = "australiaeast"

    subscription_tags = {
      cost_centre = "IT-DEV-002"
      criticality = "high"
    }

    address_space_required = "/24"
    hub_peering_enabled    = true

    subnets = {
      default = {
        subnet_prefix = "/26"
      }
      api = {
        subnet_prefix = "/28"
      }
    }

    budgets = {
      amount         = 500
      threshold      = 80
      contact_emails = ["team@example.com"]
    }

    federated_credentials_github = {
      repository = "example-api-prod"
    }
  }

  example-web-dev = {
    workload = "example-web"
    env      = "dev"
    team     = "web-engineering"
    location = "australiacentral"

    subscription_devtest_enabled = true
    subscription_tags = {
      cost_centre = "IT-DEV-001"
    }

    address_space_required = "/25"

    subnets = {
      default = {
        subnet_prefix = "/27"
      }
    }

    budgets = {
      amount         = 100
      threshold      = 90
      contact_emails = ["web-team@example.com"]
    }

    federated_credentials_github = {
      repository = "example-web-dev"
    }
  }
}
